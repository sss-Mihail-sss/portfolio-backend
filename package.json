{
  "name": "portfolio-backend-elysia",
  "version": "1.0.50",
  "module": "src/main.js",
  "scripts": {
    "test": "bun test src",
    "dev": "bun run --watch src/main.ts",
    "emit": "bun --bun prisma-next contract emit",
    "emit:check": "bun emit && git diff --exit-code src/db/schema.json src/db/schema.d.ts",
    "db:init": "bun --bun prisma-next db init",
    "migrate": "bun --bun prisma-next migrate",
    "migration:plan": "bun --bun prisma-next migration plan",
    "migration:show": "bun --bun prisma-next migration show",
    "migration:check": "bun --bun prisma-next migration check",
    "migration:graph": "bun --bun prisma-next migration graph",
    "seed": "bun run src/db/seed.ts",
    "email": "email dev --dir src/mail/templates",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "@elysia/cors": "^2.0.0-exp.1",
    "@elysia/jwt": "^2.0.0-exp.0",
    "@elysia/openapi": "2.0.0-exp.1",
    "@prisma-next/adapter-postgres": "^0.14.0",
    "@prisma-next/contract": "^0.14.0",
    "@prisma-next/driver-postgres": "^0.14.0",
    "@prisma-next/extension-pgvector": "^0.14.0",
    "@prisma-next/extension-postgis": "^0.14.0",
    "@prisma-next/family-sql": "^0.14.0",
    "@prisma-next/framework-components": "^0.14.0",
    "@prisma-next/ids": "^0.14.0",
    "@prisma-next/middleware-cache": "^0.14.0",
    "@prisma-next/postgres": "^0.14.0",
    "@prisma-next/sql-builder": "^0.14.0",
    "@prisma-next/sql-contract": "^0.14.0",
    "@prisma-next/sql-contract-ts": "^0.14.0",
    "@prisma-next/sql-orm-client": "^0.14.0",
    "@prisma-next/sql-relational-core": "^0.14.0",
    "@prisma-next/sql-runtime": "^0.14.0",
    "@prisma-next/target-postgres": "^0.14.0",
    "@react-email/ui": "^6.6.5",
    "elysia": "^2.0.0-exp.25",
    "next-intl": "^4.13.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-email": "^6.6.5",
    "resend": "^6.16.0"
  },
  "devDependencies": {
    "@prisma-next/cli": "^0.14.0",
    "@prisma-next/emitter": "^0.14.0",
    "@prisma-next/migration-tools": "^0.14.0",
    "@prisma-next/utils": "^0.14.0",
    "@types/react": "^19.2.17",
    "bun-types": "latest",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0"
  }
}
